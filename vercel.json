{
  "version": 2,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.php"
    },
    {
      "source": "/cart",
      "destination": "/cart.php"
    },
    {
      "source": "/checkout",
      "destination": "/checkout.php"
    },
    {
      "source": "/shop",
      "destination": "/shop.php"
    },
    {
      "source": "/product-detail",
      "destination": "/product-detail.php"
    },
    {
      "source": "/admin",
      "destination": "/admin/dashboard.php"
    },
    {
      "source": "/admin/login",
      "destination": "/admin/login.php"
    },
    {
      "source": "/admin/logout",
      "destination": "/admin/logout.php"
    },
    {
      "source": "/admin/orders",
      "destination": "/admin/orders.php"
    },
    {
      "source": "/admin/products",
      "destination": "/admin/products.php"
    },
    {
      "source": "/admin/product-add",
      "destination": "/admin/product_add.php"
    },
    {
      "source": "/admin/product-edit",
      "destination": "/admin/product_edit.php"
    },
    {
      "source": "/admin/register",
      "destination": "/admin/register.php"
    }
  ]
}
